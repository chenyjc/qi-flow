[Unit]
Description=QiFlow Quantitative Trading Strategy System
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/qiflow/backend
Environment="PATH=/opt/qiflow/backend/venv/bin"
ExecStart=/opt/qiflow/backend/venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8008
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target